{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["<", ">"],
    ["__", "__"]
  ],
  "autoClosingPairs": [
    { "open": "<", "close": ">", "notIn": ["string", "comment"] },
    { "open": "(", "close": ")", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["<", ">"],
    ["(", ")"]
  ]
}
