<idea-plugin>
    <id>org.solfadoc.jetbrains</id>
    <name>Solfadoc</name>
    <vendor>solfadoc</vendor>
    <description>Syntax highlighting for solfadoc notation files</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Solfadoc"
            implementationClass="org.solfadoc.SolfaFileType"
            fieldName="INSTANCE"
            language="Solfadoc"
            extensions="solfa"/>

        <lang.parserDefinition
            language="Solfadoc"
            implementationClass="org.solfadoc.parser.SolfaParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="Solfadoc"
            implementationClass="org.solfadoc.highlight.SolfaSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="org.solfadoc.highlight.SolfaColorSettingsPage"/>

        <additionalTextAttributes scheme="Darcula" file="colorSchemes/SolfadocDarcula.xml"/>
        <additionalTextAttributes scheme="Default" file="colorSchemes/SolfadocDefault.xml"/>

        <externalFormatProcessor
            implementation="org.solfadoc.format.SolfaExternalFormatProcessor"/>
    </extensions>
</idea-plugin>
